# Use https:// when control plane is behind Let's Encrypt (see infra/tls/README.md).
CONTROL_PLANE_URL=http://127.0.0.1:8000
# Showroom CMS — use https:// when Showroom runs via ./run.sh (default TLS).
# Use http:// only if you start Showroom with ./run.sh --http
CMS_URL=https://127.0.0.1:8200
CMS_API_KEY=
FACTORY_API_KEY=
DATABASE_URL=sqlite:///./data/factory.db
DEFAULT_PULLER=
DEFAULT_MODEL=
HEARTBEAT_INTERVAL_SECONDS=15
DISPATCH_INTERVAL_SECONDS=1
GATEWAY_ID=
GATEWAY_DISPLAY_NAME=Article Factory
HOST=0.0.0.0
PORT=8100
# Set true when Caddy/nginx terminates TLS in front of the API.
TRUST_PROXY_HEADERS=false
BRAVE_SEARCH_API_KEY=
